datasource db {
  provider = "postgresql"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// ==========================================
// BETTER AUTH STUDIO META TABLES
// ==========================================

model Workspace {
  id          String   @id @default(uuid())
  name        String
  dbUrl       String   // Connection string for the managed database
  redisUrl    String?  // Connection string for Redis caching / rate limits
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudioUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin") // admin, read-only
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// MANAGED BETTER AUTH TARGET CORE TABLES
// ==========================================

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  role           String    @default("user")
  banned         Boolean   @default(false)
  bannedReason   String?
  suspendedUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions       Session[]
  accounts       Account[]
  members        Member[]
  passkeys       Passkey[]
  twoFactors     TwoFactor[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
}

model Session {
  id             String   @id @default(uuid())
  userId         String
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  riskScore      Float    @default(0.0) // Session audit risk score (0 to 1)
  country        String?  // Geolocation country
  browser        String?  // Parsed browser name
  os             String?  // Parsed operating system
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  providerId            String
  providerAccountId     String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerAccountId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==========================================
// BETTER AUTH ORGANIZATIONS & TEAMS
// ==========================================

model Organization {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  logo        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members     Member[]
  invitations Invitation[]
}

model Member {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("member")
  status         String       @default("pending") // pending, accepted, rejected, expired
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ==========================================
// BETTER AUTH SECURITY & PASSKEYS
// ==========================================

model Passkey {
  id           String    @id @default(uuid())
  name         String?
  userId       String
  credentialID String    @unique
  publicKey    String
  counter      Int       @default(0)
  deviceType   String    @default("single_device") // single_device, multi_device
  backedUp     Boolean   @default(false)
  transports   String?   // comma-separated list of transport methods (usb, nfc, ble, internal)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactor {
  id          String   @id @default(uuid())
  userId      String   @unique
  secret      String
  backupCodes String   // JSON array string of encrypted backup codes
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// BETTER AUTH DEVELOPER APIS & CONTROLS
// ==========================================

model ApiKey {
  id        String    @id @default(uuid())
  name      String
  key       String    @unique
  userId    String
  scopes    String    @default("read") // comma-separated scopes
  expiresAt DateTime?
  lastUsedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  status    String   // success, failure
  ipAddress String?
  userAgent String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model RateLimit {
  id           String    @id @default(uuid())
  key          String    @unique // e.g. IP address or API key
  limit        Int
  points       Int       @default(0)
  duration     Int       // in seconds
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
